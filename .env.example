# Ces variables d'environnement sont nécessaires pour que le formulaire de contact fonctionne
# Copiez-collez ces clés dans les paramètres de votre hébergeur (Vercel ou Netlify)
# Section: Settings > Environment Variables

# Vos identifiants SMTP (ex: Gmail, Resend, Hostinger, etc.)
SMTP_HOST=smtp.votrefournisseur.com
SMTP_PORT=587
SMTP_USER=votre_email_smtp@domaine.com
SMTP_PASS=votre_mot_de_passe_securise

# L'adresse email sur laquelle vous souhaitez recevoir les messages des clients
CONTACT_EMAIL=contact@nexivo.ga
